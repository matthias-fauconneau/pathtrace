{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cargo",
			"command": "run",
			"problemMatcher": [
				"$rustc"
			],
			"label": "Foreground Background Diff",
      "args": ["--release","--","${env:HOME}/depth/meadow.exr", "${env:HOME}/depth/best3.exr", "${env:HOME}/mask.png"],
      "presentation":{"echo": false,"reveal":"silent","focus":false,"panel":"shared","showReuseMessage":false,"clear":true}
		}
	]
}